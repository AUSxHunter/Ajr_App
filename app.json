{
  "expo": {
    "name": "Ajr",
    "slug": "ajr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Ajr_logo.png",
    "scheme": "ajr",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ahmed.ajr",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/Ajr_logo.png",
        "monochromeImage": "./assets/images/Ajr_logo.png"
      },
      "package": "com.ahmed.ajr"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#3B82F6",
          "sounds": [],
          "requestScheduleExactAlarm": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ea454170-fc8b-4a70-ab6f-66bb1e34c677"
      }
    },
    "owner": "ahmed-tarek"
  }
}
